{
  "name": "@ai-arena/token-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":         "ts-node-dev --transpile-only --respawn src/main.ts",
    "dev:bridge":  "ts-node-dev --transpile-only --respawn src/workers/bridge-listener.ts",
    "dev:rebal":   "ts-node-dev --transpile-only --respawn src/workers/rebalancer.ts",
    "build":       "tsc",
    "start":       "node dist/main.js",
    "start:bridge": "node dist/workers/bridge-listener.js",
    "start:rebal":  "node dist/workers/rebalancer.js",
    "typecheck":   "tsc --noEmit"
  },
  "dependencies": {
    "fastify":           "^4.26.0",
    "@fastify/cors":     "^9.0.0",
    "@fastify/helmet":   "^11.1.0",
    "ethers":            "^6.11.0",
    "@solana/web3.js":   "^1.91.0",
    "@solana/spl-token": "^0.4.6",
    "@ai-arena/shared-types": "workspace:*",
    "@ai-arena/db-client":    "workspace:*",
    "@ai-arena/cache":        "workspace:*",
    "@ai-arena/event-bus":    "workspace:*"
  },
  "devDependencies": {
    "typescript":  "^5.4.0",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "pino-pretty": "^11.0.0"
  }
}
