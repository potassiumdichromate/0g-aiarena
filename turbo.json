{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "REDIS_URL", "NATS_URL"],
  "globalPassThroughEnv": [
    "PRIVY_APP_ID", "PRIVY_APP_SECRET",
    "JWT_SECRET", "JWT_REFRESH_SECRET", "JWT_ACCESS_EXPIRY", "JWT_REFRESH_EXPIRY",
    "CUSTODIAL_WALLET_ENCRYPTION_KEY",
    "ZEROG_COMPUTE_API_KEY", "ZEROG_COMPUTE_BASE_URL", "ZEROG_NETWORK",
    "ZEROG_EVM_RPC", "ZEROG_EVM_RPC_MAINNET", "ZEROG_EVM_RPC_TESTNET",
    "ZEROG_STORAGE_PRIVATE_KEY", "ZEROG_STORAGE_INDEXER_MAINNET", "ZEROG_STORAGE_INDEXER_TESTNET",
    "ZEROG_FLOW_CONTRACT_MAINNET", "ZEROG_MODEL_CHAT", "ZEROG_MODEL_IMAGE", "ZEROG_MODEL_AUDIO",
    "ZEROG_VERIFY_TEE", "ZEROG_PROVIDER_SORT",
    "ZEROG_INFT_CONTRACT_ADDRESS", "ZEROG_INFT_ORACLE_ADDRESS",
    "ZEROG_DEPOSIT_VAULT_ADDRESS", "ZEROG_MANUAL_PRICE_USD",
    "ZEROG_PAYMENT_CONTRACT_MAINNET",
    "SOLANA_RPC_URL", "SOLANA_PRIVATE_KEY",
    "ARENA_TOKEN_MINT", "ARENA_RESERVE_PROGRAM_ID",
    "AGENT_WALLET_PROGRAM_ID", "ESCROW_VAULT_PROGRAM_ID",
    "TOURNAMENT_PROGRAM_ID", "STAKING_PROGRAM_ID",
    "RELAYER_SOLANA_PRIVATE_KEY",
    "BASE_RPC_URL", "BASE_DEPOSIT_VAULT_ADDRESS", "BASE_USDC_ADDRESS", "BASE_USDT_ADDRESS",
    "USDC_MINT", "USDT_MINT",
    "EVM_DEPLOYER_PRIVATE_KEY", "EVM_FEE_COLLECTOR", "EVM_OWNER_ADDRESS",
    "TOKEN_SERVICE_URL", "REBALANCE_INTERVAL_MS",
    "QDRANT_URL", "QDRANT_API_KEY",
    "CLICKHOUSE_URL", "CLICKHOUSE_USER", "CLICKHOUSE_PASSWORD", "CLICKHOUSE_DB",
    "ENABLE_WAGER_BATTLES", "ENABLE_TOURNAMENTS", "ENABLE_MARKETPLACE",
    "USE_0G_COMPUTE", "USE_LOCAL_INFERENCE_FALLBACK",
    "RATE_LIMIT_MAX", "RATE_LIMIT_WINDOW_MS", "AUTH_RATE_LIMIT_MAX", "AUTH_RATE_LIMIT_WINDOW_MS",
    "BODY_LIMIT_BYTES", "ALLOWED_ORIGINS", "LOG_LEVEL", "SENTRY_DSN",
    "OTEL_EXPORTER_OTLP_ENDPOINT", "OTEL_SERVICE_NAME",
    "PORT_API_GATEWAY", "PORT_IDENTITY", "PORT_AGENT", "PORT_FINANCIAL", "PORT_GAME",
    "PORT_TELEMETRY", "PORT_BEHAVIOUR", "PORT_TRAINING", "PORT_INFERENCE", "PORT_MEMORY",
    "PORT_EMBEDDING", "PORT_MATCHMAKING", "PORT_BATTLE", "PORT_REPLAY", "PORT_TOURNAMENT",
    "PORT_ANTICHEAT", "PORT_WALLET", "PORT_ESCROW", "PORT_INFT", "PORT_PAYMENT",
    "PORT_ANALYTICS", "PORT_LEADERBOARD", "PORT_STORAGE", "PORT_NOTIFICATION", "PORT_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
