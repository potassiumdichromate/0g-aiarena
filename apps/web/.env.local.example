# Copy to .env.local (git-ignored)
# Get Privy App ID from: https://console.privy.io → Your App → Settings

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# WalletConnect Cloud project ID (optional — for WC support)
# Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# 0G chain contract addresses (fill after deploying ArenaDepositVault.sol)
NEXT_PUBLIC_ZEROG_VAULT_ADDRESS=
NEXT_PUBLIC_ZEROG_USDT_ADDRESS=
NEXT_PUBLIC_ZEROG_USDC_ADDRESS=
