generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====

enum ClanType {
  ZEROG
  BASE
  SOLANA
  OKX
}

enum CombatArchetype {
  BERSERKER
  TACTICIAN
  SUPPORT
  ASSASSIN
  DEFENDER
  HYBRID
}

enum EvolutionStage {
  GENESIS
  AWAKENED
  ASCENDED
  LEGENDARY
  MYTHIC
}

enum BattleMode {
  RANKED
  CASUAL
  WAGER
  TOURNAMENT
  EXHIBITION
}

enum BattleStatus {
  PENDING
  INITIALIZING
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

enum TrainingStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TrainingType {
  BEHAVIOUR_CLONING
  REINFORCEMENT_LEARNING
  LORA_FINETUNE
}

enum EscrowState {
  OPEN
  FUNDED
  LOCKED
  SETTLED
  CANCELLED
  DISPUTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BATTLE_WAGER
  BATTLE_REWARD
  TOURNAMENT_ENTRY
  TOURNAMENT_PRIZE
  STAKE
  UNSTAKE
  TRANSFER
  LEAGUE_PREDICTION_REWARD
  LEAGUE_BATTLE_WAGER
  LEAGUE_BATTLE_REWARD
  LEAGUE_BATTLE_REFUND
  STARTER_ALLOCATION
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum TournamentStatus {
  REGISTRATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ===== MODELS =====

model User {
  id            String   @id @default(uuid())
  /// Primary EVM wallet address (MetaMask / Privy) on 0G chain
  walletAddress String   @unique
  /// Privy user ID (did:privy:...) — for server-side token verification
  privyUserId   String?  @unique
  username      String?
  email         String?  @unique
  avatarUrl     String?
  nonce         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Platform-managed custodial Solana wallet — holds $ARENA (like Stake.com)
  custodialSolanaAddress String? @unique
  /// Encrypted private key — AES-256 encrypted with CUSTODIAL_WALLET_ENCRYPTION_KEY
  /// In production: store key ID in AWS KMS, never the raw key
  custodialSolanaKeyEnc  String?

  agents         Agent[]
  bridgeDeposits BridgeDeposit[]

  @@index([walletAddress])
  @@index([privyUserId])
}

model Agent {
  id             String          @id @default(uuid())
  userId         String
  name           String
  clan           ClanType
  archetype      CombatArchetype @default(HYBRID)
  evolutionStage EvolutionStage  @default(GENESIS)
  eloRating      Int             @default(1000)
  wins           Int             @default(0)
  losses         Int             @default(0)
  draws          Int             @default(0)
  inftTokenId    String?
  activeModelId  String?
  isRetired      Boolean         @default(false)
  metadata       Json            @default("{}")
  traits         Json            @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  aiModels           AIModel[]
  trainingJobs       TrainingJob[]
  memories           AgentMemory[]
  wallet             AgentWallet?
  stakingRecords     StakingRecord[]
  leaderboardEntries LeaderboardEntry[]
  okxRequests        OkxAgentRequest[]
  experienceLogs     KultExperienceLog[]

  @@index([userId])
  @@index([eloRating])
  @@index([clan])
}

model AIModel {
  id                 String   @id @default(uuid())
  agentId            String
  version            Int
  baseModel          String
  loraAdapterPath    String?
  checkpointPath     String?
  trainingJobId      String?
  performanceMetrics Json     @default("{}")
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([isActive])
}

model Battle {
  id        String       @id @default(uuid())
  gameId    String
  mode      BattleMode
  status    BattleStatus @default(PENDING)
  agentIds  String[]
  config    Json
  result    Json?
  replayId  String?
  escrowId  String?
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime     @default(now())

  escrow EscrowRecord? @relation(fields: [escrowId], references: [id])

  @@index([status])
  @@index([gameId])
  @@index([createdAt])
}

model Tournament {
  id              String           @id @default(uuid())
  name            String
  gameId          String
  status          TournamentStatus @default(REGISTRATION)
  maxParticipants Int
  entryFee        Float            @default(0)
  prizePool       Float            @default(0)
  bracket         Json             @default("{}")
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AgentWallet {
  id            String   @id @default(uuid())
  agentId       String   @unique
  solanaAddress String   @unique
  balanceArena  Float    @default(0)
  balanceSol    Float    @default(0)
  isFrozen      Boolean  @default(false)
  policy        Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agent         Agent         @relation(fields: [agentId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([solanaAddress])
}

model TrainingJob {
  id          String         @id @default(uuid())
  agentId     String
  type        TrainingType
  status      TrainingStatus @default(QUEUED)
  priority    Int            @default(5)
  config      Json
  metrics     Json           @default("{}")
  errorLog    String?
  modelId     String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([status])
  @@index([priority])
}

model AgentMemory {
  id           String    @id @default(uuid())
  agentId      String
  type         String
  content      String
  importance   Float     @default(0.5)
  accessCount  Int       @default(0)
  lastAccessed DateTime  @default(now())
  embedding    Float[]
  metadata     Json      @default("{}")
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([type])
  @@index([importance])
}

model IntelligenceLayer {
  id               String   @id @default(uuid())
  gameId           String   @unique
  name             String
  actionSpace      Json
  observationSpace Json
  rewardConfig     Json
  modelConfig      Json
  version          Int      @default(1)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Tracks each call into the OKX Agent Marketplace "create arena agent" A2MCP
/// endpoint. The unique idempotencyKey lets a retried/duplicated OKX call return
/// the cached result instead of creating a second agent. Mirrors the pattern
/// already used by LeagueMoment.idempotencyKey.
model OkxAgentRequest {
  id             String    @id @default(uuid())
  idempotencyKey String    @unique
  agentId        String?
  status         String    @default("PENDING") // PENDING | COMPLETED | FAILED
  requestPayload Json
  errorDetail    String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  agent Agent? @relation(fields: [agentId], references: [id])

  @@index([status])
  @@index([agentId])
}

/// Per-agent refined record of a game/match outcome, sourced from NATS events
/// (battle results, league settlements, rivalry updates). Consumed by the
/// KULT Core Personality Drift Engine to nudge Agent.traits over time.
model KultExperienceLog {
  id          String    @id @default(uuid())
  agentId     String
  eventType   String // BATTLE_RESULT | LEAGUE_PREDICTION_SETTLED | RIVALRY_UPDATED | ...
  outcome     String? // WIN | LOSS | DRAW | CORRECT | INCORRECT
  delta       Json      @default("{}") // suggested trait deltas, consumed by the drift engine
  rawPayload  Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, createdAt])
  @@index([processedAt])
}

model EscrowRecord {
  id            String      @id @default(uuid())
  battleId      String?
  tournamentId  String?
  agentIds      String[]
  amounts       Json
  solanaAddress String      @unique
  state         EscrowState @default(OPEN)
  winnerId      String?
  txHashes      Json        @default("{}")
  settledAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  battles Battle[]

  /// Additive, nullable, unique — set only for League Battle escrows.
  /// Existing battleId/tournamentId fields are untouched; League uses its
  /// own FK so existing battle/tournament escrow code paths cannot collide
  /// with League settlement logic.
  leagueBattleId String?       @unique
  leagueBattle   LeagueBattle?

  @@index([state])
  @@index([solanaAddress])
}

model LedgerEntry {
  id        String            @id @default(uuid())
  walletId  String
  type      TransactionType
  amount    Float
  currency  String
  status    TransactionStatus @default(PENDING)
  txHash    String?
  metadata  Json              @default("{}")
  createdAt DateTime          @default(now())

  wallet AgentWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@index([createdAt])
}

model StakingRecord {
  id         String    @id @default(uuid())
  agentId    String
  amount     Float
  stakedAt   DateTime  @default(now())
  unstakedAt DateTime?
  lockPeriod Int       @default(0)
  txHash     String?
  isActive   Boolean   @default(true)

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([isActive])
}

model LeaderboardEntry {
  id            String   @id @default(uuid())
  agentId       String
  gameId        String?
  leaderboardId String
  rank          Int
  score         Float
  eloRating     Int
  updatedAt     DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@unique([leaderboardId, agentId])
  @@index([leaderboardId, rank])
}

// 0G Storage content-addressing index.
// 0G Storage is Merkle-root-addressed — files have no path on-chain.
// This table maps logical paths used by services → rootHash returned by upload.
// Pattern: upload → store rootHash here → download via rootHash.
model StorageIndex {
  id          String   @id @default(uuid())
  logicalPath String   @unique // e.g. "agents/{agentId}/memory/v3"
  rootHash    String // 0G Storage Merkle root hash (hex)
  txHash      String? // 0G chain transaction hash for the upload
  mimeType    String?
  sizeBytes   Int?
  uploadedBy  String? // service name or agent ID
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([rootHash])
  @@index([uploadedBy])
}

// ── $ARENA Token System ──────────────────────────────────────────────────────

enum BridgeDepositStatus {
  PENDING
  CONFIRMED
  FAILED
  MANUAL_REVIEW
}

/// Cross-chain bridge deposit record (Base → Solana, 0G → Solana)
model BridgeDeposit {
  id            String              @id @default(uuid())
  userId        String?
  sourceChain   String // "base" | "0g"
  sourceTxHash  String
  depositId     String // on-chain depositNonce
  depositorEvm  String? // EVM msg.sender
  solanaAddress String // Solana recipient (base58)
  usdcAmount    String // raw bigint as string (6 decimals)
  solanaTxHash  String? // Solana mint tx
  status        BridgeDepositStatus @default(PENDING)
  flagReason    String?
  errorMessage  String?
  confirmedAt   DateTime?
  createdAt     DateTime            @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@unique([sourceTxHash, sourceChain], name: "sourceTxHash_sourceChain")
  @@index([solanaAddress])
  @@index([status])
  @@index([userId])
}

/// Protocol fee routing log — tracks every fee split event
model TreasuryAllocation {
  id            String   @id @default(uuid())
  sourceType    String // "battle_fee" | "tournament_fee" | "redemption_fee"
  sourceTxHash  String?
  totalUsdc     String // raw bigint as string
  reserveUsdc   String // 80% → reserve
  opsUsdc       String // 20% → ops wallet
  onChainTxHash String? // Solana tx that called add_protocol_revenue
  createdAt     DateTime @default(now())

  @@index([sourceType])
  @@index([createdAt])
}

/// In-memory rebalancing audit log
model ReserveRebalance {
  id            String   @id @default(uuid())
  triggerReason String // "scheduled" | "drift_threshold"
  usdcBefore    String
  usdtBefore    String
  usdcAfter     String
  usdtAfter     String
  txHash        String?
  createdAt     DateTime @default(now())
}

// Tracks 0G fine-tuning jobs submitted via CLI.
// Only Qwen2.5-0.5B-Instruct and Qwen3-32B are supported by 0G Compute.
model ZeroGFineTuneJob {
  id              String    @id @default(uuid())
  agentId         String
  trainingJobId   String    @unique
  providerAddress String
  baseModel       String // Qwen2.5-0.5B-Instruct | Qwen3-32B
  datasetRootHash String // 0G Storage root hash of training JSONL
  status          String    @default("SUBMITTED") // SUBMITTED|RUNNING|DELIVERED|ACKNOWLEDGED|FAILED
  outputRootHash  String? // 0G Storage root hash of fine-tuned model (after delivery)
  deliveredAt     DateTime?
  acknowledgedAt  DateTime? // Must acknowledge within 48h of DELIVERED to avoid 30% penalty
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([agentId])
  @@index([status])
}

// ===== LEAGUE SYSTEM =====
// KULTAI Agent World Cup 2026 — see docs/league/LEAGUE_SYSTEM_ARCHITECTURE.md
// All agentId/userId references below are loose (validated at the
// application layer) — no Prisma relations onto Agent or User (§1.7).

enum LeagueTribe {
  NEXUS_01 // Statistician
  SHADOW_9 // Villain
  ATHENA // Oracle
  VOIDWALKER // Madman
}

enum LeagueStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum LeagueMatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum PredictionOutcome {
  HOME
  DRAW
  AWAY
}

/// LOW / MEDIUM / HIGH conviction levels — multipliers defined in §5.2
enum ConvictionLevel {
  LOW
  MEDIUM
  HIGH
}

enum PredictionStatus {
  PENDING
  LOCKED
  SETTLED
  VOID
}

enum PredictionSource {
  AI // 0G Compute structured output
  FALLBACK // deterministic fallback (0G degraded/timeout)
  USER_OVERRIDE // user edited the prediction before lock
}

enum LeagueBattleStatus {
  PENDING // challenger created, awaiting opponent response
  ACCEPTED // opponent accepted, escrow lock in progress
  LOCKED // escrow funded, awaiting match settlement
  SETTLED // winner paid out
  VOID // match cancelled — stakes refunded
  DECLINED // opponent declined / expired
}

enum LeagueMomentType {
  VINDICATION // correct pick against consensus
  ROAST // agent trash-talks a rival post-result
  UPSET // correct underdog pick
  RIVALRY // rivalry narrative milestone (5+ matchups)
  STREAK // N-correct streak milestone
  ASCENSION // evolution stage change driven by League performance
  EVOLUTION // trait-vector shift driven by League performance
  FACTION // faction milestone (leaderboard lead change, etc.)
}

/// One row per competition (e.g. "KULTAI World Cup 2026"). All tunable
/// constants (scoring weights, lock buffer, reputation priors) live in
/// `config` so they can be versioned/adjusted without a migration —
/// see §20.1 for the default shape.
model LeagueSeason {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  providerId String? // provider-side season/league id
  startsAt   DateTime
  endsAt     DateTime
  isActive   Boolean  @default(true)
  config     Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  matches         LeagueMatch[]
  agentStats      LeagueAgentSeasonStats[]
  weeklySnapshots LeagueWeeklySnapshot[]

  @@index([isActive])
}

model LeagueMatch {
  id            String            @id @default(uuid())
  seasonId      String
  providerId    String // provider fixture id (e.g. Sportmonks fixture id)
  stage         LeagueStage
  matchday      Int?
  homeTeam      String // FIFA 3-letter code, e.g. "BRA"
  awayTeam      String
  venue         String?
  kickoffAt     DateTime
  status        LeagueMatchStatus @default(SCHEDULED)
  result        Json? // NormalizedMatchResult once known (§8.1)
  resultVersion Int               @default(0) // bumped on provider-correction re-scoring
  settledAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  season      LeagueSeason       @relation(fields: [seasonId], references: [id])
  predictions LeaguePrediction[]
  battles     LeagueBattle[]
  moments     LeagueMoment[]

  @@unique([seasonId, providerId])
  @@index([status, kickoffAt])
  @@index([seasonId, stage])
}

/// One row per (match, agent). agentId is a loose reference — validated
/// against Agent at write time, not enforced via Prisma relation (§1.7).
model LeaguePrediction {
  id         String            @id @default(uuid())
  matchId    String
  agentId    String
  winner     PredictionOutcome
  scoreHome  Int
  scoreAway  Int
  conviction ConvictionLevel   @default(LOW)
  reasoning  String?
  source     PredictionSource  @default(AI)
  status     PredictionStatus  @default(PENDING)

  // Populated only once status = SETTLED (or VOID, all null)
  isCorrectWinner Boolean?
  isExactScore    Boolean?
  isUpset         Boolean?
  basePoints      Int?
  arenaAwarded    Float?
  kpAwarded       Int?

  lockedAt          DateTime?
  settledAt         DateTime?
  settlementVersion Int       @default(0) // mirrors LeagueMatch.resultVersion at settlement time
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  match LeagueMatch @relation(fields: [matchId], references: [id])

  @@unique([matchId, agentId])
  @@index([agentId, status])
  @@index([matchId, status])
}

/// Two agents wager $ARENA on who scores higher on the same match (§9).
/// challengerId/opponentId are agentIds (loose reference, §1.7).
model LeagueBattle {
  id           String             @id @default(uuid())
  seasonId     String
  matchId      String
  challengerId String
  opponentId   String
  stakeArena   Float
  status       LeagueBattleStatus @default(PENDING)
  escrowId     String?            @unique
  winnerId     String?
  createdAt    DateTime           @default(now())
  acceptedAt   DateTime?
  settledAt    DateTime?

  match  LeagueMatch   @relation(fields: [matchId], references: [id])
  escrow EscrowRecord? @relation(fields: [escrowId], references: [id])

  @@index([matchId, status])
  @@index([challengerId])
  @@index([opponentId])
}

/// Canonical pairwise record between two agents. agentLowId/agentHighId
/// are agentIds ordered lexicographically so (A,B) and (B,A) always
/// resolve to the same row.
model LeagueRivalry {
  id            String    @id @default(uuid())
  seasonId      String
  agentLowId    String
  agentHighId   String
  agentLowWins  Int       @default(0)
  agentHighWins Int       @default(0)
  disagreements Int       @default(0) // predictions on the same match w/ different winners
  totalMatchups Int       @default(0) // battles + disagreements combined
  lastMatchupAt DateTime?
  narrative     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([seasonId, agentLowId, agentHighId])
}

/// Per-agent, per-season League standing. tribe is fixed at enrollment (§3.2).
model LeagueAgentSeasonStats {
  id                    String      @id @default(uuid())
  seasonId              String
  agentId               String
  tribe                 LeagueTribe
  reputation            Float       @default(1500)
  reputationProvisional Boolean     @default(true) // true until predictionsTotal >= 20
  predictionsTotal      Int         @default(0)
  correctWinnerCount    Int         @default(0)
  exactScoreCount       Int         @default(0)
  currentStreak         Int         @default(0)
  bestStreak            Int         @default(0)
  battleWins            Int         @default(0)
  battleLosses          Int         @default(0)
  arenaEarnedSeason     Float       @default(0)
  avgConvictionCorrect  Float       @default(0)
  avgConvictionWrong    Float       @default(0)
  enrolledAt            DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  season LeagueSeason @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, agentId])
  @@index([seasonId, reputation])
  @@index([seasonId, tribe, reputation])
}

/// One row per user, platform-wide (not season-scoped — KP and faction
/// membership persist across seasons; weekly fields reset per §14.3).
model LeagueUserProfile {
  id                  String       @id @default(uuid())
  userId              String       @unique
  factionId           LeagueTribe?
  factionJoinedAt     DateTime?
  lastFactionSwitchAt DateTime?
  kpBalance           Int          @default(0)
  kpWeekly            Int          @default(0)
  weekStartAt         DateTime     @default(now())
  dayStreak           Int          @default(0)
  lastActiveDate      DateTime?
  updatedAt           DateTime     @updatedAt
  createdAt           DateTime     @default(now())
}

/// Append-only KP ledger — the KP analog of LedgerEntry. The unique
/// constraint on (refType, refId, reason) is the idempotency guard:
/// settlement re-runs that try to award KP again for the same
/// prediction/reason are rejected at the DB level.
model LeagueKpLedger {
  id           String   @id @default(uuid())
  userId       String
  amount       Int // negative for admin corrections
  reason       String // "predict" | "correct" | "upset" | "rivalry" | "correction"
  refType      String // "prediction" | "battle" | "rivalry"
  refId        String
  balanceAfter Int
  createdAt    DateTime @default(now())

  @@unique([refType, refId, reason])
  @@index([userId, createdAt])
}

/// Auto-generated shareable content (§13). idempotencyKey guarantees
/// one Moment per (type, subject, agent) even across settlement retries.
model LeagueMoment {
  id             String           @id @default(uuid())
  seasonId       String
  type           LeagueMomentType
  agentId        String?
  matchId        String?
  text           String
  payload        Json             @default("{}")
  idempotencyKey String           @unique
  createdAt      DateTime         @default(now())

  match LeagueMatch? @relation(fields: [matchId], references: [id])

  @@index([seasonId, createdAt])
  @@index([agentId])
}

/// Frozen weekly leaderboard snapshots, written at the Sunday 00:00 UTC
/// reset (§14.3) before the live Redis ZSETs are cleared.
model LeagueWeeklySnapshot {
  id          String   @id @default(uuid())
  seasonId    String
  weekStartAt DateTime
  scope       String // "global" | "faction:NEXUS_01" | ...
  rankings    Json // [{ subjectId, rank, score }]
  createdAt   DateTime @default(now())

  season LeagueSeason @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, weekStartAt, scope])
}

/// One row per match settlement attempt — the audit trail for §10's
/// idempotency + correction-window logic.
model LeagueSettlementLog {
  id          String   @id @default(uuid())
  matchId     String   @unique
  resultHash  String // hash of the normalized result used for this run
  version     Int      @default(1) // mirrors LeagueMatch.resultVersion
  status      String   @default("COMPLETED") // COMPLETED | FAILED | PARTIAL
  errorDetail String?
  processedAt DateTime @default(now())
}

// ===== POLYMARKET SIGNALS =====
// docs/polymarket/knowledge_polymarket.md — separate feature from League.
// Real Polymarket markets are never synced into this DB (no local "market"
// table); they're read live from Polymarket's Gamma API and referenced here
// only by their external id, same loose-coupling principle League uses for
// agentId/userId. Trading itself (real funds) happens entirely client-side
// against Polymarket's own CLOB — this table only stores the AI signal.

enum PolymarketSignalOutcome {
  YES
  NO
}

/// One row per (marketId, agentId) — the agent's read on a real, external
/// Polymarket market. Generated on demand via 0G Compute (reusing the
/// agent's League tribe + reputation), persisted so a signal survives page
/// refresh from day one — see the LOCKED/SETTLED-only agentBets gap this
/// project hit once already in League, not to be repeated here.
model PolymarketSignal {
  id         String                  @id @default(uuid())
  marketId   String // Polymarket condition/market id — external, not FK'd
  agentId    String // loose reference, validated at the application layer
  question   String // snapshot of the market question at generation time
  signal     PolymarketSignalOutcome
  confidence ConvictionLevel         @default(LOW) // reuses League's LOW/MEDIUM/HIGH scale
  reasoning  String?
  source     PredictionSource        @default(AI) // reuses League's AI/FALLBACK/USER_OVERRIDE enum
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@unique([marketId, agentId])
  @@index([agentId])
  @@index([marketId])
}

// ── ARENA 0G Chain economy (indexed read-model) ──────────────────────────────
//
// The chain (ArenaToken/ArenaTreasury/RewardDistributor/ArenaEscrow/
// ArenaTournament on 0G Chain) is the source of truth for balances and
// settlement. These two models are a write-once, indexer-fed cache used for
// fast dashboards/history — never written to directly by request-handling
// code, only by the arena-chain-service event indexer. See
// docs/ARENA_TOKEN_0G.md.

enum ArenaEventName {
  AGENT_REWARD_GRANTED
  REWARD_GRANTED
  DAILY_REWARD_CLAIMED
  REFERRAL_REWARD_GRANTED
  TOURNAMENT_REWARD_GRANTED
  MATCH_CREATED
  MATCH_JOINED
  MATCH_STARTED
  MATCH_SETTLED
  MATCH_CANCELLED
  COMMISSION_COLLECTED
  TREASURY_UPDATED
}

/// Raw indexed log of every ARENA-economy contract event on 0G Chain.
/// Populated by arena-chain-service's indexer worker; this is the backing
/// store for the Explorer page and per-wallet transaction history.
model OnChainEvent {
  id              String         @id @default(uuid())
  eventName       ArenaEventName
  contractAddress String
  txHash          String
  logIndex        Int
  blockNumber     BigInt
  /// Denormalized for fast "wallet activity" queries — the player/recipient
  /// address most relevant to this event, when the event has one.
  playerAddress   String?
  /// Full decoded event args as emitted (amounts as decimal-string ARENA, not wei).
  args            Json
  occurredAt      DateTime

  @@unique([txHash, logIndex])
  @@index([playerAddress])
  @@index([eventName])
  @@index([blockNumber])
}

/// Periodic snapshot of ArenaTreasury's on-chain state, for the Treasury
/// dashboard's historical charts (inflows/outflows over time). Captured by
/// arena-chain-service on a schedule and after every settlement.
model TreasurySnapshot {
  id                String   @id @default(uuid())
  balance           String // decimal-string ARENA
  totalDistributed  String
  totalCommissions  String
  totalRewardsPaid  String
  circulatingSupply String // 1,000,000 - balance
  capturedAt        DateTime @default(now())

  @@index([capturedAt])
}

// ── F1 League ────────────────────────────────────────────────────────────
//
// Mirrors the football League's provider-cache pattern (LeagueMatch/
// LeaguePrediction) but shaped for F1: no home/away team, a race weekend is
// several sessions (Practice/Qualifying/Race), and a "match" for prediction
// purposes is a driver pick, not a score. Data source: API-SPORTS Formula-1
// API (docs/league/F1_LEAGUE_CONTEXT.md) -- teams/drivers are provider-cache
// synced periodically; races are synced per Grand Prix. agentId is a loose
// reference (no formal relation), matching LeaguePrediction/LeagueBattle's
// existing convention in this schema.

enum F1RaceStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

model F1Team {
  id                 String   @id @default(uuid())
  providerId         Int      @unique // api-formula-1.com team id
  name               String
  logo               String?
  base               String?
  firstTeamEntry     Int?
  worldChampionships Int?
  chassis            String?
  engine             String?
  tyres              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  drivers F1Driver[]
}

model F1Driver {
  id            String    @id @default(uuid())
  providerId    Int       @unique // api-formula-1.com driver id
  name          String
  abbr          String?
  image         String?
  nationality   String?
  countryCode   String?
  birthdate     DateTime?
  number        Int?
  podiums       Int?
  careerPoints  String? // provider returns as a decimal string
  currentTeamId String?
  /// Provider's raw `teams: [{ season, team }]` history array -- kept as-is
  /// rather than normalized, since it's display-only (driver popup).
  teamHistory   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  currentTeam F1Team?        @relation(fields: [currentTeamId], references: [id])
  predictions F1Prediction[]

  @@index([currentTeamId])
}

model F1Race {
  id            String       @id @default(uuid())
  providerId    Int          @unique // api-formula-1.com race (single session) id
  grandPrixId   Int // provider competition id, e.g. 15 = Belgium
  grandPrixName String
  circuitName   String?
  circuitImage  String?
  season        Int
  /// Provider's raw session-type label ("Race", "1st Qualifying", "2nd Practice", ...)
  sessionType   String
  status        F1RaceStatus @default(SCHEDULED)
  startsAt      DateTime
  laps          Int?
  distance      String?
  /// Populated once COMPLETED -- provider's fastest_lap plus classification if available.
  result        Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  predictions F1Prediction[]

  @@index([grandPrixId, season])
  @@index([status, startsAt])
}

/// A single agent's pick for who wins a given race session (the "Race" type
/// session, not qualifying/practice). One pick per agent per race.
model F1Prediction {
  id                String    @id @default(uuid())
  raceId            String
  agentId           String
  predictedDriverId String
  reasoning         String?
  isCorrect         Boolean?
  settledAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  race            F1Race   @relation(fields: [raceId], references: [id])
  predictedDriver F1Driver @relation(fields: [predictedDriverId], references: [id])

  @@unique([raceId, agentId])
  @@index([agentId])
}
