# =============================================================================
# AI ARENA — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in real values before running.
# Docs: https://docs.0g.ai/developer-hub/building-on-0g
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL — primary transactional store (Prisma ORM)
DATABASE_URL=postgresql://ai_arena:password@localhost:5433/ai_arena
# ClickHouse — time-series telemetry + analytics (replaces TimescaleDB)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=ai_arena
CLICKHOUSE_PASSWORD=password
CLICKHOUSE_DB=ai_arena_analytics

# ── Cache & Messaging ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# 0G ECOSYSTEM — OFFICIAL PARTNER INTEGRATION
# =============================================================================

# ── 0G Chain ──────────────────────────────────────────────────────────────────
# Mainnet: Chain ID 16661 | Testnet: Chain ID 16600
# Active environment: mainnet | testnet
ZEROG_NETWORK=mainnet
ZEROG_CHAIN_ID_MAINNET=16661
ZEROG_CHAIN_ID_TESTNET=16600
ZEROG_EVM_RPC_MAINNET=https://evmrpc.0g.ai
ZEROG_EVM_RPC_TESTNET=https://evmrpc-testnet.0g.ai
ZEROG_EXPLORER=https://chainscan.0g.ai

# ── 0G Storage ────────────────────────────────────────────────────────────────
# SDK: npm install @0gfoundation/0g-storage-ts-sdk ethers
# IMPORTANT: Files are identified by Merkle ROOT HASH — not by path strings.
# We maintain a path→rootHash index in PostgreSQL (table: storage_index).

# Mainnet indexer (turbo network)
ZEROG_STORAGE_INDEXER_MAINNET=https://indexer-storage-turbo.0g.ai
# Testnet indexer (turbo network)
ZEROG_STORAGE_INDEXER_TESTNET=https://indexer-storage-testnet-turbo.0g.ai

# Private key for the platform wallet that signs storage transactions
# Use HashiCorp Vault in production — NEVER commit the real value
ZEROG_STORAGE_PRIVATE_KEY=0x309b5ca4e4a8894cc034a21900eaf3ff86ad89200c1317d32d22ce4ce6d91508

# 0G Storage smart contract addresses (mainnet)
ZEROG_FLOW_CONTRACT_MAINNET=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526
ZEROG_MINE_CONTRACT_MAINNET=0xCd01c5Cd953971CE4C2c9bFb95610236a7F414fe
ZEROG_REWARD_CONTRACT_MAINNET=0x457aC76B58ffcDc118AABD6DbC63ff9072880870

# ── 0G Compute Router ─────────────────────────────────────────────────────────
# OpenAI-compatible API base URL (same for mainnet and testnet)
ZEROG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1

# API key — create at pc.0g.ai → Dashboard → API Keys
# Requires "inference" permission. Format: sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Docs: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/router/authentication
ZEROG_COMPUTE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Payment contract for depositing 0G tokens (funds inference billing)
# Deposit at pc.0g.ai → Dashboard → Deposit
# Billing unit: neuron (1e18 neuron = 1 0G token)
ZEROG_PAYMENT_CONTRACT_MAINNET=0xA3b15Bd2aD18BFB6b5f92D8AA9F444Dd59d1cE32
ZEROG_PAYMENT_CONTRACT_TESTNET=0x0AD9690e0b34aB2d493DE02cDF149ee34f6C9939

# Available models (source: pc.0g.ai/models — verified 2026-07-17)
#
# IMPORTANT: model IDs are the bare slug shown on each model's detail page
# (e.g. pc.0g.ai/models/glm-5.1 → "glm-5.1"), NOT the old OpenRouter-style
# "provider/model" form ("deepseek/deepseek-chat-v3-0324", "zai-org/GLM-5.1-FP8")
# used by earlier defaults here — those no longer resolve on the router, so any
# service still pointed at them silently falls through to deterministic
# fallback logic instead of a real model response.
#
# Chat / Reasoning:
#   glm-5.1                            — GLM-5.1, strong tool-calling ← recommended
#   deepseek-v4-pro                    — DeepSeek V4 Pro, strongest reasoning
#   deepseek-v4-flash                  — DeepSeek V4 Flash, cheap/low-latency
#   qwen3.7-max                        — Qwen3.7 Max, tool calling + web search
#
# Image Generation:
#   z-image                            — Avatar / image generation
#   Always use response_format: b64_json — URL format not yet supported
#
# Audio Transcription:
#   openai/whisper-large-v3            — Multilingual audio-to-text

ZEROG_MODEL_CHAT=glm-5.1
ZEROG_MODEL_IMAGE=z-image
ZEROG_MODEL_AUDIO=openai/whisper-large-v3

# Enable TEE verifiable execution per inference request (true | false)
# Adds "verify_tee": true to requests; result in x_0g_trace.tee_verified
# Slight latency overhead — enable for high-trust pipelines and audit logs
ZEROG_VERIFY_TEE=false

# Provider routing preference for inference requests
# Options: latency | price | (empty = round-robin)
ZEROG_PROVIDER_SORT=latency

# ── 0G Compute Fine-tuning ────────────────────────────────────────────────────
# Fine-tuning uses the 0G Compute CLI: @0gfoundation/0g-compute-ts-sdk
# Install: pnpm install @0gfoundation/0g-compute-ts-sdk -g (requires Node >= 22)
# Supported base models ONLY:
#   - Qwen2.5-0.5B-Instruct  (0.5 0G/M tokens, 0.01 0G storage fee)
#   - Qwen3-32B               (4.0 0G/M tokens, 0.09 0G storage fee)
# Provider address from: 0g-compute-cli fine-tuning list-providers
ZEROG_FINETUNE_PROVIDER=
ZEROG_FINETUNE_DEFAULT_MODEL=Qwen2.5-0.5B-Instruct

# ── 0G INFT (ERC-7857) ───────────────────────────────────────────────────────
# Living AI agent NFTs — GitHub: https://github.com/0gfoundation/0g-agent-nft
# ERC-7857 extends ERC-721 with: transfer(sealedKey,proof), clone, authorizeUsage
# Encrypted metadata stored on 0G Storage; oracle handles re-encryption on transfer
ZEROG_INFT_CONTRACT_ADDRESS=
ZEROG_INFT_ORACLE_ADDRESS=

# =============================================================================
# SOLANA
# =============================================================================
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=23f9c53a-0072-4c99-a9b8-7cba8a779d49
SOLANA_PRIVATE_KEY=BfH8Y84oF9jujjg2pY3s7XxDQ4BHSEJV7muvGyWQEbbtFjccJCGd9qHNzdQVdq6vD8AbRSTGxwQwSRyKbZHyJys
AGENT_WALLET_PROGRAM_ID=
ESCROW_VAULT_PROGRAM_ID=
TOURNAMENT_PROGRAM_ID=
STAKING_PROGRAM_ID=
ARENA_TOKEN_MINT=
ARENA_RESERVE_PROGRAM_ID=ARsv11111111111111111111111111111111111111

# =============================================================================
# $ARENA TOKEN / BRIDGE SERVICE
# =============================================================================
# Solana relayer keypair (base64-encoded secret key) — use AWS KMS in prod
RELAYER_SOLANA_PRIVATE_KEY=CTFYI5XR59n8GDoxf9akUjKbhKZrRSPYXYpyurkof8wcN7+NcNou8eQGpJ3lrOyONzl3HxlxdajCuCPuFj3Hhg==

# ── Deployer wallet (only for contract deployment — never used at runtime) ─────
EVM_DEPLOYER_PRIVATE_KEY=0x309b5ca4e4a8894cc034a21900eaf3ff86ad89200c1317d32d22ce4ce6d91508
EVM_FEE_COLLECTOR=0x63F63DC442299cCFe470657a769fdC6591d65eCa
EVM_OWNER_ADDRESS=0x63F63DC442299cCFe470657a769fdC6591d65eCa

# ── Base mainnet (chainId 8453) ───────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
# Deployed ArenaDepositVault address on Base (fill after: pnpm deploy:vault:base)
BASE_DEPOSIT_VAULT_ADDRESS=
# Official token addresses on Base mainnet (do not change — these are canonical)
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BASE_USDT_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
# BaseScan API key for contract verification (optional, get at https://basescan.org/myapikey)
BASESCAN_API_KEY=

# ── 0G mainnet (chainId 16661) ────────────────────────────────────────────────
# ZEROG_EVM_RPC is already set above as ZEROG_EVM_RPC_MAINNET
ZEROG_EVM_RPC=https://evmrpc.0g.ai
# Deployed ArenaDepositVault address on 0G (fill after: pnpm deploy:vault:zerog)
ZEROG_DEPOSIT_VAULT_ADDRESS=
# Manual 0G token USD price fallback (used if CoinGecko is down)
ZEROG_MANUAL_PRICE_USD=0.05

# Token service upstream (used by api-gateway)
TOKEN_SERVICE_URL=http://localhost:8050

# Rebalancer schedule (milliseconds, default 6h)
REBALANCE_INTERVAL_MS=21600000

# =============================================================================
# ARENA FINANCE BACKEND (External Service)
# =============================================================================
ARENA_FINANCE_API_URL=
ARENA_FINANCE_API_KEY=

# =============================================================================
# AUTH — PRIVY (MetaMask login on 0G chain)
# =============================================================================
# Create app at https://console.privy.io → get App ID + App Secret
PRIVY_APP_ID=cmhfx1cl20001l10d4l0w8u4j
PRIVY_APP_SECRET=your-privy-app-secret-here

# Custodial wallet encryption key — AES-256 (exactly 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CUSTODIAL_WALLET_ENCRYPTION_KEY=e04d3521fba1126e2d1a5fb1c52751f4

JWT_SECRET=22bcc58190b4cc19ec2ea43d58ce827a49c1ef62d647747bf130b0f785934749
JWT_REFRESH_SECRET=73a8abd6af5fcdffb707367d77571b043c06eac1f82ff5297c83d84a546c791f
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# SERVICE PORTS
# =============================================================================
PORT_API_GATEWAY=8000
PORT_IDENTITY=8001
PORT_AGENT=8002
PORT_FINANCIAL=8003
PORT_GAME=8004
PORT_TELEMETRY=8010
PORT_BEHAVIOUR=8011
PORT_TRAINING=8012
PORT_INFERENCE=8013
PORT_MEMORY=8014
PORT_EMBEDDING=8015
PORT_MATCHMAKING=8020
PORT_BATTLE=8021
PORT_REPLAY=8022
PORT_TOURNAMENT=8023
PORT_ANTICHEAT=8024
PORT_WALLET=8030
PORT_ESCROW=8031
PORT_INFT=8032
PORT_PAYMENT=8033
PORT_ANALYTICS=8040
PORT_LEADERBOARD=8041
PORT_STORAGE=8042
PORT_NOTIFICATION=8043
PORT_TOKEN=8050

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_WAGER_BATTLES=false
ENABLE_TOURNAMENTS=false
ENABLE_MARKETPLACE=false
# Use 0G Compute Router for inference (true) or local heuristic fallback (false)
USE_0G_COMPUTE=true
# Fall back to heuristic AI if 0G Compute times out (recommended: true)
USE_LOCAL_INFERENCE_FALLBACK=true

# =============================================================================
# OBSERVABILITY
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=info

# OpenTelemetry — traces sent to Jaeger OTLP gRPC endpoint (docker-compose: jaeger:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-arena
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Prometheus scrape port (each service exposes GET /metrics)
# Grafana UI:     http://localhost:3001  (admin / GRAFANA_ADMIN_PASSWORD)
# Prometheus UI:  http://localhost:9090
# Jaeger UI:      http://localhost:16686
GRAFANA_ADMIN_PASSWORD=d729446*

# =============================================================================
# SECURITY
# =============================================================================
# API Gateway global rate limit (requests per window, per wallet/IP)
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000
# Auth endpoint stricter limit (credential-stuffing protection)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
# Max inbound request body size in bytes (default 1 MB)
BODY_LIMIT_BYTES=1048576
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
