# =============================================================================
# AI ARENA — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in real values before running.
# Docs: https://docs.0g.ai/developer-hub/building-on-0g
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ai_arena:password@localhost:5432/ai_arena
TIMESCALE_URL=postgresql://ai_arena:password@localhost:5433/telemetry
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Cache & Messaging ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# 0G ECOSYSTEM — OFFICIAL PARTNER INTEGRATION
# =============================================================================

# ── 0G Chain ──────────────────────────────────────────────────────────────────
# Mainnet: Chain ID 16661 | Testnet: Chain ID 16600
# Active environment: mainnet | testnet
ZEROG_NETWORK=mainnet
ZEROG_CHAIN_ID_MAINNET=16661
ZEROG_CHAIN_ID_TESTNET=16600
ZEROG_EVM_RPC_MAINNET=https://evmrpc.0g.ai
ZEROG_EVM_RPC_TESTNET=https://evmrpc-testnet.0g.ai
ZEROG_EXPLORER=https://chainscan.0g.ai

# ── 0G Storage ────────────────────────────────────────────────────────────────
# SDK: npm install @0gfoundation/0g-storage-ts-sdk ethers
# IMPORTANT: Files are identified by Merkle ROOT HASH — not by path strings.
# We maintain a path→rootHash index in PostgreSQL (table: storage_index).

# Mainnet indexer (turbo network)
ZEROG_STORAGE_INDEXER_MAINNET=https://indexer-storage-turbo.0g.ai
# Testnet indexer (turbo network)
ZEROG_STORAGE_INDEXER_TESTNET=https://indexer-storage-testnet-turbo.0g.ai

# Private key for the platform wallet that signs storage transactions
# Use HashiCorp Vault in production — NEVER commit the real value
ZEROG_STORAGE_PRIVATE_KEY=0x_your_private_key_here

# 0G Storage smart contract addresses (mainnet)
ZEROG_FLOW_CONTRACT_MAINNET=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526
ZEROG_MINE_CONTRACT_MAINNET=0xCd01c5Cd953971CE4C2c9bFb95610236a7F414fe
ZEROG_REWARD_CONTRACT_MAINNET=0x457aC76B58ffcDc118AABD6DbC63ff9072880870

# ── 0G Compute Router ─────────────────────────────────────────────────────────
# OpenAI-compatible API base URL (same for mainnet and testnet)
ZEROG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1

# API key — create at pc.0g.ai → Dashboard → API Keys
# Requires "inference" permission. Format: sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Docs: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/router/authentication
ZEROG_COMPUTE_API_KEY=sk-your-key-here

# Payment contract for depositing 0G tokens (funds inference billing)
# Deposit at pc.0g.ai → Dashboard → Deposit
# Billing unit: neuron (1e18 neuron = 1 0G token)
ZEROG_PAYMENT_CONTRACT_MAINNET=0xA3b15Bd2aD18BFB6b5f92D8AA9F444Dd59d1cE32
ZEROG_PAYMENT_CONTRACT_TESTNET=0x0AD9690e0b34aB2d493DE02cDF149ee34f6C9939

# Available models (source: pc.0g.ai/api-reference — verified 2025-05-08)
#
# Chat / Reasoning:
#   deepseek/deepseek-chat-v3-0324     — DeepSeek V3, strong reasoning
#   qwen/qwen3-vl-30b-a3b-instruct     — Qwen3 multimodal (vision + text)
#   qwen3.6-plus                       — Qwen3.6 Plus
#   zai-org/GLM-5-FP8                  — GLM-5 (FP8 quantised)
#   zai-org/GLM-5.1-FP8                — GLM-5.1 (FP8 quantised) ← recommended
#
# Image Generation:
#   z-image                            — Avatar / image generation
#   Always use response_format: b64_json — URL format not yet supported
#
# Audio Transcription:
#   openai/whisper-large-v3            — Multilingual audio-to-text

ZEROG_MODEL_CHAT=zai-org/GLM-5.1-FP8
ZEROG_MODEL_IMAGE=z-image
ZEROG_MODEL_AUDIO=openai/whisper-large-v3

# Enable TEE verifiable execution per inference request (true | false)
# Adds "verify_tee": true to requests; result in x_0g_trace.tee_verified
# Slight latency overhead — enable for high-trust pipelines and audit logs
ZEROG_VERIFY_TEE=false

# Provider routing preference for inference requests
# Options: latency | price | (empty = round-robin)
ZEROG_PROVIDER_SORT=latency

# ── 0G Compute Fine-tuning ────────────────────────────────────────────────────
# Fine-tuning uses the 0G Compute CLI: @0gfoundation/0g-compute-ts-sdk
# Install: pnpm install @0gfoundation/0g-compute-ts-sdk -g (requires Node >= 22)
# Supported base models ONLY:
#   - Qwen2.5-0.5B-Instruct  (0.5 0G/M tokens, 0.01 0G storage fee)
#   - Qwen3-32B               (4.0 0G/M tokens, 0.09 0G storage fee)
# Provider address from: 0g-compute-cli fine-tuning list-providers
ZEROG_FINETUNE_PROVIDER=
ZEROG_FINETUNE_DEFAULT_MODEL=Qwen2.5-0.5B-Instruct

# ── 0G INFT (ERC-7857) ───────────────────────────────────────────────────────
# Living AI agent NFTs — GitHub: https://github.com/0gfoundation/0g-agent-nft
# ERC-7857 extends ERC-721 with: transfer(sealedKey,proof), clone, authorizeUsage
# Encrypted metadata stored on 0G Storage; oracle handles re-encryption on transfer
ZEROG_INFT_CONTRACT_ADDRESS=
ZEROG_INFT_ORACLE_ADDRESS=

# =============================================================================
# SOLANA
# =============================================================================
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=
AGENT_WALLET_PROGRAM_ID=
ESCROW_VAULT_PROGRAM_ID=
TOURNAMENT_PROGRAM_ID=
STAKING_PROGRAM_ID=
ARENA_TOKEN_MINT=

# =============================================================================
# ARENA FINANCE BACKEND (External Service)
# =============================================================================
ARENA_FINANCE_API_URL=
ARENA_FINANCE_API_KEY=

# =============================================================================
# AUTH
# =============================================================================
JWT_SECRET=change_me_in_production_minimum_32_characters
JWT_REFRESH_SECRET=change_me_in_production_minimum_32_characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# SERVICE PORTS
# =============================================================================
PORT_API_GATEWAY=8000
PORT_IDENTITY=8001
PORT_AGENT=8002
PORT_FINANCIAL=8003
PORT_GAME=8004
PORT_TELEMETRY=8010
PORT_BEHAVIOUR=8011
PORT_TRAINING=8012
PORT_INFERENCE=8013
PORT_MEMORY=8014
PORT_EMBEDDING=8015
PORT_MATCHMAKING=8020
PORT_BATTLE=8021
PORT_REPLAY=8022
PORT_TOURNAMENT=8023
PORT_ANTICHEAT=8024
PORT_WALLET=8030
PORT_ESCROW=8031
PORT_INFT=8032
PORT_PAYMENT=8033
PORT_ANALYTICS=8040
PORT_LEADERBOARD=8041
PORT_STORAGE=8042
PORT_NOTIFICATION=8043

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_WAGER_BATTLES=false
ENABLE_TOURNAMENTS=false
ENABLE_MARKETPLACE=false
# Use 0G Compute Router for inference (true) or local heuristic fallback (false)
USE_0G_COMPUTE=true
# Fall back to heuristic AI if 0G Compute times out (recommended: true)
USE_LOCAL_INFERENCE_FALLBACK=true

# =============================================================================
# OBSERVABILITY
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
