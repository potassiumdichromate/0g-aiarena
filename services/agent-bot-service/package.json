{
  "name": "@ai-arena/agent-bot-service",
  "version": "0.1.0",
  "private": true,
  "description": "Continuously mints filler agents on a random 30-60min schedule so real players always have opponents to face.",
  "scripts": {
    "dev": "ts-node-dev --transpile-only --respawn src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/helmet": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0"
  }
}
